      m_Calls: []
  m_text: "The year is 2045. Global warming, corrupt government, and ruthless megacorporations
    have rendered the surface of Earth uninhabitable, known as \u201CThe Reckoning\u201D.
    All that remains of humanity now lives on 9 flying megacities high above the
    clouds. These 9 megacities are known as \u201CThe Flotilla\u201D."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
