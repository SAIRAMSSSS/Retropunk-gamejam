  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The Flotilla is controlled by the last remaining megacorporation, \u201COmniworks
    International\u201D. Omniworks ruthlessly reigns over The Flotilla as judge,
    jury, and executioner; everyone either has a purpose, or is disposable. Since
    Omniworks rules with an iron fist, crime and resistance to Omniworks runs rampant
    across The Flotilla.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
